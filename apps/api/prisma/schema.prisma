// Baile Latino Platform — schema de la API. PostgreSQL (dev y prod).
// Dev local: Postgres vía docker-compose. Prod: Postgres gestionado (Railway/Neon).
//
// NOTA: los campos "enum" se guardan como String validados contra los arrays de
// @baile-latino/types, y las listas (p. ej. estilos del usuario) como CSV (se
// mantiene así por compatibilidad histórica).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: la URL no va aquí. Para migraciones/db push vive en prisma.config.ts;
  // en runtime el cliente se conecta vía driver adapter (pg) — ver prisma.service.ts.
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String? // opcional: los usuarios que solo entran con Google no tienen contraseña
  googleId        String?  @unique // vinculación con cuenta de Google
  emailVerified   Boolean  @default(false) // true si un proveedor (Google) verificó el email
  name            String
  role            String   @default("BAILARIN") // UserRole
  city            String?
  instagramHandle String?
  styles          String   @default("") // CSV de DanceStyle
  refreshTokenHash String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tracksCreated  Track[]        @relation("TrackCreatedBy")
  tracksAsArtist Track[]        @relation("TrackArtist")
  ownedTracks    Track[]        @relation("TrackOwner")
  library        UserTrack[]
  trackTags      TrackTag[]
  playlists      Playlist[]
  songRequests   SongRequest[]
  requestVotes   RequestVote[]

  @@index([role])
}

model Track {
  id             String   @id @default(cuid())
  title          String
  artist         String
  style          String // DanceStyle
  substyle       String? // DanceSubstyle
  year           Int?
  source         String // TrackSource: SPOTIFY | YOUTUBE
  sourceId       String
  coverUrl       String?
  durationSec    Int?
  isRelease      Boolean  @default(false)
  approvalStatus String   @default("APROBADA") // TrackApprovalStatus
  scope          String   @default("CATALOG") // TrackScope: CATALOG (global) | PERSONAL (privada del DJ)
  ownerId        String? // dueño cuando scope = PERSONAL
  ytMetadata     String? // JSON con todos los datos extraídos de YouTube (snippet, stats, status, etc.)
  artistUserId   String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner         User?          @relation("TrackOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  artistUser    User?          @relation("TrackArtist", fields: [artistUserId], references: [id], onDelete: SetNull)
  createdBy     User           @relation("TrackCreatedBy", fields: [createdById], references: [id])
  playlistItems PlaylistItem[]
  songRequests  SongRequest[]
  savedBy       UserTrack[]
  trackTags     TrackTag[]

  // Sin unique global de (source,sourceId): el mismo video puede estar en el
  // catálogo y además como copia personal de uno o más DJs. Dedupe en la app.
  @@index([source, sourceId])
  @@index([scope])
  @@index([ownerId])
  @@index([style])
  @@index([substyle])
}

/// Configuración global de la plataforma (clave/valor JSON). P.ej. la matriz
/// de permisos rol×módulo (ver/editar/eliminar).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Vocabulario global de tags (sub-estilos). Único por `slug` normalizado
/// (sin distinguir mayúsculas/acentos/puntuación). Lo administra el SUPER_ADMIN,
/// pero un DJ también puede crear uno nuevo al etiquetar.
model Tag {
  id          String   @id @default(cuid())
  name        String // texto a mostrar
  slug        String // normalizado para deduplicar (único por estilo, no global)
  style       String? // categoría: BACHATA | SALSA | null (general)
  createdById String
  createdAt   DateTime @default(now())

  tracks TrackTag[]

  // El mismo nombre puede existir en cada estilo (ej: "Romántica" en bachata y salsa).
  @@unique([slug, style])
}

/// Asociación DJ↔canción↔tag (cada DJ etiqueta según su apreciación).
model TrackTag {
  id        String   @id @default(cuid())
  trackId   String
  userId    String
  tagId     String
  createdAt DateTime @default(now())

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([trackId, userId, tagId])
  @@index([trackId])
  @@index([tagId])
  @@index([userId])
}

/// Biblioteca personal: canciones (de catálogo o personales) en "Mis Canciones".
model UserTrack {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
}

model Playlist {
  id               String   @id @default(cuid())
  name             String
  eventId          String? // FK lógica al futuro EventsModule (sin constraint aún)
  status           String   @default("BORRADOR") // PlaylistStatus
  visibility       String   @default("SOLO_ENTRADA") // PlaylistVisibility
  targetBachataPct Int? // 0-100; resto se asume salsa
  ownerId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner User           @relation(fields: [ownerId], references: [id])
  items PlaylistItem[]

  @@index([ownerId])
  @@index([eventId])
}

model PlaylistItem {
  id         String  @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  isWarmup   Boolean @default(false)
  addedById  String

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId])
}

model SongRequest {
  id          String   @id @default(cuid())
  eventId     String?
  trackId     String
  requesterId String
  status      String   @default("PENDIENTE") // SongRequestStatus
  createdAt   DateTime @default(now())

  track     Track         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  requester User          @relation(fields: [requesterId], references: [id])
  votes     RequestVote[]

  @@index([eventId])
  @@index([trackId])
}

model RequestVote {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  createdAt DateTime @default(now())

  request SongRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([requestId, userId])
}
