# Base de datos: PostgreSQL (dev y prod) vía adapter-pg.
# Dev local: levanta Postgres con `docker compose up -d db` (ver docker-compose.yml).
# Prod: usa la URL del Postgres gestionado (Railway/Neon).
DATABASE_URL="postgresql://baile:baile@localhost:5432/baile"

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="cambia-esto-tambien-otro-secreto"

# Emails que SIEMPRE son SUPER_ADMIN (separados por coma). Al entrar (por Google
# o password) con uno de estos correos, la cuenta queda como super admin.
SUPER_ADMIN_EMAILS="jhuacarios@gmail.com"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3000
WEB_URL="http://localhost:3001"
NODE_ENV="development"

# Integraciones de música (no requeridas para arrancar la API)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Redirect del OAuth de Spotify (conectar la cuenta y leer sus playlists). DEBE
# estar en "Redirect URIs" de la app en el Spotify Developer Dashboard. En dev
# usa 127.0.0.1 (Spotify no acepta "localhost" como loopback):
SPOTIFY_OAUTH_REDIRECT_URI="http://127.0.0.1:3000/api/v1/music/spotify/callback"
# ── YouTube / Google — SEGMENTAR POR ENTORNO ──────────────────────────────────
# IMPORTANTE: dev y prod deben usar credenciales de Google DISTINTAS (proyecto de
# Google Cloud aparte para cada uno). La cuota de la API de YouTube (10.000
# unidades/día) es POR PROYECTO: si dev y prod comparten la key, probar en local
# le quema la cuota a producción. Ver DEPLOY.md → "Segmentación de entornos".
#   - dev  → key + cliente OAuth del proyecto "nectason-dev" (redirects a localhost)
#   - prod → key + cliente OAuth del proyecto de producción (redirects a la URL real)
YOUTUBE_API_KEY=

# Google OAuth — cliente de YOUTUBE (scope sensible auth/youtube). Este es el que
# necesita verificación de Google para publicarse; en dev/piloto queda en Testing.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google OAuth — cliente de LOGIN (solo scopes básicos: openid email profile).
# Va en un proyecto de Google APARTE cuyo consent screen NO tenga el scope de
# YouTube, para poder PUBLICARLO sin auditoría y que cualquiera inicie sesión.
# Si se dejan vacías, el login cae a los GOOGLE_OAUTH_* de arriba (útil en dev).
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
# Redirect del login con Google. DEBE estar en "Authorized redirect URIs" del
# cliente OAuth de LOGIN. En dev queda este por defecto:
GOOGLE_LOGIN_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"
