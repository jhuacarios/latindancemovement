# Base de datos: PostgreSQL (dev y prod) vía adapter-pg.
# Dev local: levanta Postgres con `docker compose up -d db` (ver docker-compose.yml).
# Prod: usa la URL del Postgres gestionado (Railway/Neon).
DATABASE_URL="postgresql://baile:baile@localhost:5432/baile"

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="cambia-esto-tambien-otro-secreto"

# Emails que SIEMPRE son SUPER_ADMIN (separados por coma). Al entrar (por Google
# o password) con uno de estos correos, la cuenta queda como super admin.
SUPER_ADMIN_EMAILS="jhuacarios@gmail.com"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3000
WEB_URL="http://localhost:3001"
NODE_ENV="development"

# Integraciones de música (no requeridas para arrancar la API)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Redirect del OAuth de Spotify (conectar la cuenta y leer sus playlists). DEBE
# estar en "Redirect URIs" de la app en el Spotify Developer Dashboard. En dev
# usa 127.0.0.1 (Spotify no acepta "localhost" como loopback):
SPOTIFY_OAUTH_REDIRECT_URI="http://127.0.0.1:3000/api/v1/music/spotify/callback"
YOUTUBE_API_KEY=

# Google OAuth (login con Google + conexión de YouTube). Mismo cliente para ambos.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Redirect del login con Google. DEBE estar en "Authorized redirect URIs" del
# cliente OAuth en Google Cloud Console. En dev queda este por defecto:
GOOGLE_LOGIN_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"
